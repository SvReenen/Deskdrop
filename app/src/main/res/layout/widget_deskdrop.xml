<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:gravity="center"
    android:padding="8dp"
    android:background="@drawable/widget_background">

    <ImageButton
        android:id="@+id/btn_voice"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:src="@drawable/ic_shortcut_mic"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/shortcut_dictate"
        android:scaleType="centerInside"
        android:padding="8dp" />

    <ImageButton
        android:id="@+id/btn_chat"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:src="@drawable/ic_shortcut_chat"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/shortcut_new_chat"
        android:scaleType="centerInside"
        android:padding="8dp" />

    <ImageButton
        android:id="@+id/btn_execute"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:src="@drawable/ic_widget_execute"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:contentDescription="Execute"
        android:scaleType="centerInside"
        android:padding="8dp" />

</LinearLayout>
