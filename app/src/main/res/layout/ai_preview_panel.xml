<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/ai_preview_panel"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:visibility="gone"
    android:clipChildren="false">

    <!-- Animated glow border (top edge) -->
    <View
        android:id="@+id/ai_preview_glow"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:layout_gravity="top" />

    <!-- Shimmer overlay shown during AI processing -->
    <View
        android:id="@+id/ai_preview_shimmer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        android:alpha="0.15" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Clipboard context indicator -->
        <TextView
            android:id="@+id/ai_preview_context_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="16dp"
            android:paddingTop="8dp"
            android:paddingBottom="4dp"
            android:textSize="12sp"
            android:textColor="#801A9E8F"
            android:visibility="gone"
            android:singleLine="true"
            android:ellipsize="end" />

        <ScrollView
            android:id="@+id/ai_preview_scroll"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingStart="16dp"
            android:paddingEnd="24dp"
            android:paddingTop="16dp"
            android:clipToPadding="false"
            android:fillViewport="true"
            android:scrollbarStyle="outsideInset">

            <TextView
                android:id="@+id/ai_preview_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textColor="#B3FFFFFF"
                android:lineSpacingMultiplier="1.3"
                android:paddingBottom="16dp" />

        </ScrollView>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:paddingHorizontal="12dp"
            android:paddingTop="4dp">

            <LinearLayout
                android:id="@+id/ai_preview_chips"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical" />

        </HorizontalScrollView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingHorizontal="12dp"
            android:paddingVertical="4dp">

            <TextView
                android:id="@+id/ai_preview_dismiss"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:gravity="center"
                android:paddingHorizontal="12dp"
                android:text="✕"
                android:textSize="20sp"
                android:textColor="#80FFFFFF"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/ai_preview_copy"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:gravity="center"
                android:paddingHorizontal="12dp"
                android:text="⧉"
                android:textSize="20sp"
                android:textColor="#80FFFFFF"
                android:clickable="true"
                android:focusable="true" />

            <TextView
                android:id="@+id/ai_preview_retry"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:gravity="center"
                android:paddingHorizontal="12dp"
                android:text="↻"
                android:textSize="20sp"
                android:textColor="#80FFFFFF"
                android:clickable="true"
                android:focusable="true" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <Button
                android:id="@+id/ai_preview_edit"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:layout_marginEnd="8dp"
                android:text="Edit"
                android:textSize="14sp"
                android:textColor="#B3FFFFFF"
                style="?android:attr/buttonBarButtonStyle" />

            <Button
                android:id="@+id/ai_preview_apply"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:paddingHorizontal="24dp"
                android:text="Apply"
                android:textSize="14sp"
                android:textColor="@android:color/white"
                android:backgroundTint="#FF1A9E8F" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
